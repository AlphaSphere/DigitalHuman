# 本地桌面模式（不用 Docker）— 由 combined_launcher.py 自动写入/覆盖关键项
LOCAL_DESKTOP_MODE=true

DATABASE_URL=sqlite:///./storage/digital_human.db
REDIS_URL=redis://127.0.0.1:6379/0
STORAGE_ROOT=./storage

WHISPER_BASE_URL=
# 留空则优先使用本地 whisper 命令；Stub 模式下返回示例文案而非真实识别
COZYVOICE_BASE_URL=http://127.0.0.1:8002
HEYGEM_BASE_URL=http://127.0.0.1:8003
# === 真实 AI 配音（推荐）===
# 1. 运行 scripts/windows/安装CosyVoice.bat
# 2. 设置以下变量并 ALLOW_MODEL_SERVICE_STUB_OUTPUT=false
COSYVOICE_UPSTREAM_URL=http://127.0.0.1:50000
COSYVOICE_UPSTREAM_MODE=official_fastapi
COSYVOICE_SFT_SPK_ID=中文女
COSYVOICE_REPO_PATH=./external/CosyVoice
# === 真实数字人口型（需 Docker + HeyGem/Duix.Avatar :8383）===
HEYGEM_VIDEO_BASE_URL=
ALLOW_MODEL_SERVICE_STUB_OUTPUT=false
TUILIONNX_BASE_URL=http://127.0.0.1:8004

PLAYWRIGHT_CHROME_CDP_URL=http://127.0.0.1:9222

MUSIC_LIBRARY_PATH=./storage/music
USE_STUB_MODEL_ADAPTERS=false
ENABLE_DISTRIBUTION=false

# KrLongAI 对齐
ENABLE_URL_IMPORT=true
URL_DOWNLOAD_COMMAND=yt-dlp
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
ENABLE_LLM_REWRITE=true
ENABLE_COVER_GENERATION=true
FFMPEG_COMMAND=ffmpeg
FFPROBE_COMMAND=ffprobe

VITE_API_BASE_URL=/api
