DATABASE_URL=mysql+pymysql://digital_human:digital_human@mysql:3306/digital_human
REDIS_URL=redis://redis:6379/0
STORAGE_ROOT=/app/storage

WHISPER_BASE_URL=http://whisper:8001
WHISPER_COMMAND=whisper
WHISPER_MODEL=base
WHISPER_LANGUAGE=zh
WHISPER_DEVICE=

COZYVOICE_BASE_URL=http://cozyvoice:8002
COSYVOICE_UPSTREAM_URL=
# digitalhuman: 调用本项目包装协议 /synthesize；official_fastapi: 调用 CosyVoice 官方 /inference_*。
COSYVOICE_UPSTREAM_MODE=official_fastapi
COSYVOICE_COMMAND_TEMPLATE=
COSYVOICE_MODEL_DIR=
COSYVOICE_SFT_SPK_ID=中文女
COSYVOICE_PROMPT_TEXT=
COSYVOICE_TARGET_SAMPLE_RATE=22050
COSYVOICE_WORKDIR=/opt/cosyvoice
COSYVOICE_TIMEOUT_SECONDS=600
COSYVOICE_REPO_PATH=./external/CosyVoice

HEYGEM_BASE_URL=http://heygem:8003
HEYGEM_UPSTREAM_URL=
# HeyGem 官方视频合成服务地址，通常是 http://host.docker.internal:8383 或 http://duix-avatar-gen-video:8383。
HEYGEM_VIDEO_BASE_URL=
HEYGEM_COMMAND_TEMPLATE=
HEYGEM_DEFAULT_VIDEO_PATH=
HEYGEM_AVATAR_PROFILE_MAP=
HEYGEM_RESULT_DIR=
HEYGEM_DATA_PATH=./external/duix_avatar_data
HEYGEM_POLL_INTERVAL_SECONDS=5
HEYGEM_POLL_TIMEOUT_SECONDS=1800
HEYGEM_WORKDIR=/opt/heygem
HEYGEM_TIMEOUT_SECONDS=1800
HEYGEM_REPO_PATH=./external/HeyGem.ai

MODEL_HTTP_TIMEOUT_SECONDS=600
ALLOW_MODEL_SERVICE_STUB_OUTPUT=false
FFMPEG_COMMAND=ffmpeg
FFPROBE_COMMAND=ffprobe

MUSIC_LIBRARY_PATH=/app/storage/music
ENABLE_BACKGROUND_MUSIC=true

SOCIAL_AUTO_UPLOAD_COMMAND=sau
SOCIAL_AUTO_UPLOAD_ACCOUNT=default
SOCIAL_AUTO_UPLOAD_WORKDIR=
SOCIAL_AUTO_UPLOAD_TIMEOUT_SECONDS=900
ENABLE_DISTRIBUTION=false

# true 时使用本地占位产物跑通链路；接入真实模型服务后改为 false。
# 注意：CosyVoice/HeyGem 独立服务还需要配置对应 COMMAND_TEMPLATE 或 UPSTREAM_URL。
USE_STUB_MODEL_ADAPTERS=true

VITE_API_BASE_URL=http://localhost:8000/api
